---
import Base from './Base.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;

const base = import.meta.env.BASE_URL;
const link = (path: string) => (base + path.replace(/^\//, '')).replace(/\/+/g, '/');
const current = Astro.url.pathname.replace(base, '/').replace(/\/+$/, '') || '/';

const subnav = [
  { href: '/icons', label: 'overview' },
  { href: '/icons/browse', label: 'browse' },
];
---

<Base title={title}>
  <slot name="head" slot="head" />
  <nav class="icons-subnav" aria-label="sethmakes-icons">
    {subnav.map((item) => (
      <a
        href={link(item.href)}
        class:list={['icons-subnav__link', { 'icons-subnav__link--active': current === item.href }]}
        aria-current={current === item.href ? 'page' : undefined}
      >{item.label}</a>
    ))}
  </nav>
  <slot />

  <style>
    /* Mirrors Ui.astro's subnav: surface-2 strip, muted links, moss on hover,
       bold + full-strength text for the active page. Same feel, own namespace. */
    .icons-subnav {
      display: flex;
      flex-wrap: wrap;
      gap: var(--mk-space-2) var(--mk-space-4);
      padding: var(--mk-space-2) var(--mk-space-3);
      margin-bottom: var(--mk-space-6);
      background: var(--mk-color-surface-2);
      font-size: var(--mk-text-sm);
    }

    .icons-subnav__link {
      color: var(--mk-color-text-muted);
    }

    .icons-subnav__link:hover {
      color: var(--mk-color-accent-hover);
    }

    .icons-subnav__link--active {
      color: var(--mk-color-text);
      font-weight: var(--mk-weight-bold);
    }
  </style>
</Base>
