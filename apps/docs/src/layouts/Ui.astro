---
import Base from './Base.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;

const base = import.meta.env.BASE_URL;
const link = (path: string) => (base + path.replace(/^\//, '')).replace(/\/+/g, '/');
const current = Astro.url.pathname.replace(base, '/').replace(/\/+$/, '') || '/';

const subnav = [
  { href: '/ui', label: 'overview' },
  { href: '/ui/components/typography', label: 'type' },
  { href: '/ui/components/buttons', label: 'buttons' },
  { href: '/ui/components/forms', label: 'forms' },
  { href: '/ui/components/surfaces', label: 'surfaces' },
  { href: '/ui/components/feedback', label: 'feedback' },
  { href: '/ui/components/media', label: 'media' },
  { href: '/ui/tokens', label: 'tokens' },
];
---

<Base title={title}>
  <slot name="head" slot="head" />
  <nav class="ui-subnav" aria-label="sethmakes-ui">
    {subnav.map((item) => (
      <a
        href={link(item.href)}
        class:list={['ui-subnav__link', { 'ui-subnav__link--active': current === item.href }]}
        aria-current={current === item.href ? 'page' : undefined}
      >{item.label}</a>
    ))}
  </nav>
  <slot />

  <style>
    .ui-subnav {
      display: flex;
      flex-wrap: wrap;
      gap: var(--mk-space-2) var(--mk-space-4);
      padding: var(--mk-space-2) var(--mk-space-3);
      margin-bottom: var(--mk-space-6);
      background: var(--mk-color-surface-2);
      font-size: var(--mk-text-sm);
    }

    .ui-subnav__link {
      color: var(--mk-color-text-muted);
    }

    .ui-subnav__link:hover {
      color: var(--mk-color-accent-hover);
    }

    .ui-subnav__link--active {
      color: var(--mk-color-text);
      font-weight: var(--mk-weight-bold);
    }
  </style>
</Base>
