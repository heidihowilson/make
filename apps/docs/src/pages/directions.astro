---
import Base from '../layouts/Base.astro';
---

<Base title="Directions">
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;600;700&family=JetBrains+Mono:wght@400;600;700&family=Space+Grotesk:wght@400;600;700&display=swap"
    />
  </Fragment>

  <h1>Directions</h1>
  <p>
    Three complete takes on <em>minimalist grayscale, flat, 1–3 accents</em>.
    React to the whole vibe, not the parts. Check both color modes (toggle, top
    right) before judging.
  </p>

  <nav class="directions-nav">
    <button class="mk-btn mk-btn--primary" data-direction="terminal">Terminal</button>
    <button class="mk-btn mk-btn--primary" data-direction="stark">Stark</button>
    <button class="mk-btn mk-btn--primary" data-direction="press">Press</button>
  </nav>
  <p class="direction-blurb" id="direction-blurb"></p>

  <section class="mk-card tuner">
    <fieldset class="tuner__group">
      <legend>Accent shade</legend>
      <label><input type="radio" name="shade" value="phosphor" checked /><span class="swatch sw-phosphor"></span>Phosphor (150)</label>
      <label><input type="radio" name="shade" value="moss" /><span class="swatch sw-moss"></span>Moss — muted (150)</label>
      <label><input type="radio" name="shade" value="matrix" /><span class="swatch sw-matrix"></span>Matrix — vivid (145)</label>
      <label><input type="radio" name="shade" value="emerald" /><span class="swatch sw-emerald"></span>Emerald (163)</label>
      <label><input type="radio" name="shade" value="forest" /><span class="swatch sw-forest"></span>Forest — deep (155)</label>
      <label><input type="radio" name="shade" value="mint" /><span class="swatch sw-mint"></span>Mint — soft (170)</label>
      <label><input type="radio" name="shade" value="jade" /><span class="swatch sw-jade"></span>Jade — gray-green (175)</label>
      <label><input type="radio" name="shade" value="olive" /><span class="swatch sw-olive"></span>Olive — earthy (120)</label>
      <label><input type="radio" name="shade" value="acid" /><span class="swatch sw-acid"></span>Acid (125)</label>
      <label><input type="radio" name="shade" value="amber" /><span class="swatch sw-amber"></span>Amber (80)</label>
      <label><input type="radio" name="shade" value="cyan" /><span class="swatch sw-cyan"></span>Cyan (200)</label>
    </fieldset>
    <fieldset class="tuner__group">
      <legend>Accent role</legend>
      <label>
        <input type="radio" name="role" value="hero" checked />
        Hero — accent fills primary buttons
      </label>
      <label>
        <input type="radio" name="role" value="punctuation" />
        Punctuation — primary buttons are inverted ink; accent only marks (links, badges, focus, progress)
      </label>
    </fieldset>
  </section>

  <section class="mk-card" style="margin-top: var(--mk-space-5);">
    <h2>Specimen</h2>
    <p>
      The quick brown fox jumps over the lazy dog — 0123456789.
      <span class="mk-badge mk-badge--accent">accent</span>
      <span class="mk-badge mk-badge--warning">warning</span>
      <span class="mk-badge mk-badge--success">success</span>
    </p>

    <h3>Components</h3>
    <p style="display: flex; gap: var(--mk-space-3); flex-wrap: wrap; align-items: center;">
      <button class="mk-btn mk-btn--primary">Add show</button>
      <button class="mk-btn">Mark watched</button>
      <button class="mk-btn mk-btn--ghost">Cancel</button>
      <a href="#specimen">A text link</a>
    </p>

    <div class="mk-field" style="max-width: 24rem;">
      <label for="demo-input">Show title</label>
      <input id="demo-input" class="mk-input" placeholder="Search for a show…" />
      <span class="mk-field__help">Filled fields — zero borders, tonal background.</span>
    </div>

    <p style="margin-top: var(--mk-space-4);">
      <progress class="mk-progress" max="100" value="62"></progress>
    </p>

    <div class="mk-card" style="background: var(--mk-color-surface-2); margin-top: var(--mk-space-4);">
      <h4>Nested surface</h4>
      <p style="color: var(--mk-color-text-muted);">
        surface-2 on surface-1 on bg — hierarchy without a single border.
      </p>
    </div>
  </section>

  <style>
    .directions-nav {
      display: flex;
      gap: var(--mk-space-3);
      flex-wrap: wrap;
    }

    .direction-blurb {
      color: var(--mk-color-text-muted);
      font-size: var(--mk-text-sm);
      min-height: 2.5em;
    }

    .tuner {
      display: grid;
      grid-template-columns: 1fr;
      gap: var(--mk-space-5);
    }

    @media (min-width: 40rem) {
      .tuner {
        grid-template-columns: 1fr 1.4fr;
      }
    }

    /* fieldset reset — zero borders/chrome; legend styled like a label */
    .tuner__group {
      border: 0;
      margin: 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: var(--mk-space-2);
    }

    .tuner__group > legend {
      padding: 0;
      margin-bottom: var(--mk-space-2);
      font-size: var(--mk-text-lg);
      font-weight: var(--mk-weight-bold);
    }

    .tuner__group label {
      display: flex;
      align-items: center;
      gap: var(--mk-space-2);
      cursor: pointer;
      font-size: var(--mk-text-sm);
    }

    .swatch {
      display: inline-block;
      width: 1.1em;
      height: 1.1em;
      border-radius: var(--mk-radius-sm);
      flex-shrink: 0;
    }

    .sw-phosphor { background: light-dark(oklch(50% 0.14 150), oklch(76% 0.18 150)); }
    .sw-moss { background: light-dark(oklch(48% 0.08 150), oklch(75% 0.1 150)); }
    .sw-matrix { background: light-dark(oklch(55% 0.18 145), oklch(85% 0.23 145)); }
    .sw-emerald { background: light-dark(oklch(55% 0.14 163), oklch(78% 0.15 163)); }
    .sw-forest { background: light-dark(oklch(45% 0.11 155), oklch(70% 0.13 155)); }
    .sw-mint { background: light-dark(oklch(60% 0.1 170), oklch(85% 0.11 170)); }
    .sw-jade { background: light-dark(oklch(50% 0.07 175), oklch(76% 0.08 175)); }
    .sw-olive { background: light-dark(oklch(50% 0.09 120), oklch(74% 0.1 120)); }
    .sw-acid { background: light-dark(oklch(52% 0.16 125), oklch(80% 0.2 125)); }
    .sw-amber { background: light-dark(oklch(58% 0.13 80), oklch(80% 0.15 80)); }
    .sw-cyan { background: light-dark(oklch(50% 0.1 200), oklch(78% 0.12 200)); }
  </style>

  <script is:inline>
    const DIRECTIONS = {
      terminal: {
        blurb:
          'Monospace everywhere, zero radius, phosphor green + amber. The machine speaks plainly.',
        vars: {
          '--mk-font-body': "'JetBrains Mono', ui-monospace, monospace",
          '--mk-radius-sm': '0px',
          '--mk-radius-control': '0px',
          '--mk-radius-surface': '0px',
          '--mk-radius-pill': '0px',
          '--mk-color-accent': 'light-dark(oklch(50% 0.14 150), oklch(76% 0.18 150))',
          '--mk-color-accent-hover': 'light-dark(oklch(43% 0.13 150), oklch(83% 0.19 150))',
          '--mk-color-accent-contrast': 'light-dark(oklch(99% 0 0), oklch(13% 0 0))',
          '--mk-color-accent-subtle': 'light-dark(oklch(94% 0.06 150), oklch(28% 0.07 150))',
          '--mk-color-on-accent-subtle': 'light-dark(oklch(40% 0.12 150), oklch(85% 0.14 150))',
          '--mk-color-focus': 'light-dark(oklch(50% 0.14 150), oklch(76% 0.18 150))',
        },
      },
      stark: {
        blurb:
          'Geist grotesk, modest radius, inverted-ink primary, blue reserved for focus. Vercel-adjacent severity.',
        vars: {
          '--mk-font-body': "'Geist', system-ui, sans-serif",
          '--mk-radius-sm': '4px',
          '--mk-radius-control': '6px',
          '--mk-radius-surface': '8px',
          '--mk-radius-pill': '8px',
          '--mk-color-accent': 'light-dark(oklch(15% 0 0), oklch(98% 0 0))',
          '--mk-color-accent-hover': 'light-dark(oklch(32% 0 0), oklch(86% 0 0))',
          '--mk-color-accent-contrast': 'light-dark(oklch(99% 0 0), oklch(13% 0 0))',
          '--mk-color-accent-subtle': 'light-dark(oklch(92% 0 0), oklch(28% 0 0))',
          '--mk-color-on-accent-subtle': 'light-dark(oklch(25% 0 0), oklch(90% 0 0))',
          '--mk-color-focus': 'light-dark(oklch(55% 0.19 255), oklch(70% 0.15 255))',
        },
      },
      press: {
        blurb:
          'Space Grotesk, 2px corners, one vermilion accent used like a rubber stamp. Print-shop energy.',
        vars: {
          '--mk-font-body': "'Space Grotesk', system-ui, sans-serif",
          '--mk-radius-sm': '2px',
          '--mk-radius-control': '2px',
          '--mk-radius-surface': '2px',
          '--mk-radius-pill': '2px',
          '--mk-color-accent': 'light-dark(oklch(55% 0.21 28), oklch(68% 0.19 28))',
          '--mk-color-accent-hover': 'light-dark(oklch(48% 0.2 28), oklch(75% 0.17 28))',
          '--mk-color-accent-contrast': 'light-dark(oklch(99% 0 0), oklch(13% 0 0))',
          '--mk-color-accent-subtle': 'light-dark(oklch(93% 0.04 28), oklch(27% 0.08 28))',
          '--mk-color-on-accent-subtle': 'light-dark(oklch(45% 0.17 28), oklch(82% 0.12 28))',
          '--mk-color-focus': 'light-dark(oklch(55% 0.21 28), oklch(68% 0.19 28))',
        },
      },
    };

    const SHADES = {
      phosphor: {
        '--mk-color-accent': 'light-dark(oklch(50% 0.14 150), oklch(76% 0.18 150))',
        '--mk-color-accent-hover': 'light-dark(oklch(43% 0.13 150), oklch(83% 0.19 150))',
        '--mk-color-accent-subtle': 'light-dark(oklch(94% 0.06 150), oklch(28% 0.07 150))',
        '--mk-color-on-accent-subtle': 'light-dark(oklch(40% 0.12 150), oklch(85% 0.14 150))',
      },
      moss: {
        '--mk-color-accent': 'light-dark(oklch(48% 0.08 150), oklch(75% 0.1 150))',
        '--mk-color-accent-hover': 'light-dark(oklch(42% 0.08 150), oklch(82% 0.11 150))',
        '--mk-color-accent-subtle': 'light-dark(oklch(94% 0.04 150), oklch(27% 0.05 150))',
        '--mk-color-on-accent-subtle': 'light-dark(oklch(38% 0.07 150), oklch(86% 0.08 150))',
      },
      matrix: {
        '--mk-color-accent': 'light-dark(oklch(55% 0.18 145), oklch(85% 0.23 145))',
        '--mk-color-accent-hover': 'light-dark(oklch(48% 0.17 145), oklch(90% 0.24 145))',
        '--mk-color-accent-subtle': 'light-dark(oklch(94% 0.08 145), oklch(28% 0.09 145))',
        '--mk-color-on-accent-subtle': 'light-dark(oklch(42% 0.15 145), oklch(88% 0.18 145))',
      },
      emerald: {
        '--mk-color-accent': 'light-dark(oklch(55% 0.14 163), oklch(78% 0.15 163))',
        '--mk-color-accent-hover': 'light-dark(oklch(48% 0.13 163), oklch(84% 0.16 163))',
        '--mk-color-accent-subtle': 'light-dark(oklch(94% 0.06 163), oklch(28% 0.07 163))',
        '--mk-color-on-accent-subtle': 'light-dark(oklch(42% 0.12 163), oklch(86% 0.13 163))',
      },
      forest: {
        '--mk-color-accent': 'light-dark(oklch(45% 0.11 155), oklch(70% 0.13 155))',
        '--mk-color-accent-hover': 'light-dark(oklch(39% 0.1 155), oklch(77% 0.14 155))',
        '--mk-color-accent-subtle': 'light-dark(oklch(93% 0.05 155), oklch(26% 0.06 155))',
        '--mk-color-on-accent-subtle': 'light-dark(oklch(36% 0.09 155), oklch(84% 0.11 155))',
      },
      mint: {
        '--mk-color-accent': 'light-dark(oklch(60% 0.1 170), oklch(85% 0.11 170))',
        '--mk-color-accent-hover': 'light-dark(oklch(53% 0.1 170), oklch(90% 0.12 170))',
        '--mk-color-accent-subtle': 'light-dark(oklch(95% 0.05 170), oklch(29% 0.06 170))',
        '--mk-color-on-accent-subtle': 'light-dark(oklch(42% 0.09 170), oklch(88% 0.1 170))',
      },
      jade: {
        '--mk-color-accent': 'light-dark(oklch(50% 0.07 175), oklch(76% 0.08 175))',
        '--mk-color-accent-hover': 'light-dark(oklch(44% 0.07 175), oklch(82% 0.09 175))',
        '--mk-color-accent-subtle': 'light-dark(oklch(94% 0.03 175), oklch(27% 0.04 175))',
        '--mk-color-on-accent-subtle': 'light-dark(oklch(38% 0.06 175), oklch(86% 0.07 175))',
      },
      olive: {
        '--mk-color-accent': 'light-dark(oklch(50% 0.09 120), oklch(74% 0.1 120))',
        '--mk-color-accent-hover': 'light-dark(oklch(44% 0.09 120), oklch(80% 0.11 120))',
        '--mk-color-accent-subtle': 'light-dark(oklch(94% 0.04 120), oklch(27% 0.05 120))',
        '--mk-color-on-accent-subtle': 'light-dark(oklch(38% 0.08 120), oklch(85% 0.09 120))',
      },
      acid: {
        '--mk-color-accent': 'light-dark(oklch(52% 0.16 125), oklch(80% 0.2 125))',
        '--mk-color-accent-hover': 'light-dark(oklch(45% 0.15 125), oklch(86% 0.21 125))',
        '--mk-color-accent-subtle': 'light-dark(oklch(94% 0.07 125), oklch(28% 0.08 125))',
        '--mk-color-on-accent-subtle': 'light-dark(oklch(40% 0.13 125), oklch(88% 0.15 125))',
      },
      amber: {
        '--mk-color-accent': 'light-dark(oklch(58% 0.13 80), oklch(80% 0.15 80))',
        '--mk-color-accent-hover': 'light-dark(oklch(50% 0.12 80), oklch(86% 0.16 80))',
        '--mk-color-accent-subtle': 'light-dark(oklch(95% 0.06 80), oklch(29% 0.07 80))',
        '--mk-color-on-accent-subtle': 'light-dark(oklch(45% 0.11 80), oklch(87% 0.12 80))',
      },
      cyan: {
        '--mk-color-accent': 'light-dark(oklch(50% 0.1 200), oklch(78% 0.12 200))',
        '--mk-color-accent-hover': 'light-dark(oklch(44% 0.1 200), oklch(84% 0.13 200))',
        '--mk-color-accent-subtle': 'light-dark(oklch(94% 0.05 200), oklch(28% 0.06 200))',
        '--mk-color-on-accent-subtle': 'light-dark(oklch(40% 0.09 200), oklch(86% 0.1 200))',
      },
    };

    const PUNCTUATION_CSS = `
      .mk-btn--primary {
        background: light-dark(oklch(15% 0 0), oklch(98% 0 0));
        color: light-dark(oklch(99% 0 0), oklch(13% 0 0));
      }
      .mk-btn--primary:hover {
        background: light-dark(oklch(32% 0 0), oklch(86% 0 0));
      }
    `;

    const ALL_VARS = [
      ...new Set([
        ...Object.values(DIRECTIONS).flatMap((d) => Object.keys(d.vars)),
        ...Object.values(SHADES).flatMap((s) => Object.keys(s)),
      ]),
    ];
    const blurb = document.getElementById('direction-blurb');
    const roleStyle = document.createElement('style');
    document.head.appendChild(roleStyle);

    const state = {
      direction: localStorage.getItem('mk-direction') || 'terminal',
      shade: localStorage.getItem('mk-shade') || 'phosphor',
      role: localStorage.getItem('mk-role') || 'hero',
    };
    if (!DIRECTIONS[state.direction]) state.direction = 'terminal';
    if (!SHADES[state.shade]) state.shade = 'phosphor';

    const apply = () => {
      const dir = DIRECTIONS[state.direction];
      ALL_VARS.forEach((v) => document.documentElement.style.removeProperty(v));
      Object.entries(dir.vars).forEach(([k, v]) =>
        document.documentElement.style.setProperty(k, v)
      );
      // Shade + role tune the Terminal direction only.
      if (state.direction === 'terminal') {
        Object.entries(SHADES[state.shade]).forEach(([k, v]) =>
          document.documentElement.style.setProperty(k, v)
        );
        document.documentElement.style.setProperty(
          '--mk-color-focus',
          'var(--mk-color-accent)'
        );
        roleStyle.textContent = state.role === 'punctuation' ? PUNCTUATION_CSS : '';
      } else {
        roleStyle.textContent = '';
      }
      blurb.textContent = dir.blurb;
      localStorage.setItem('mk-direction', state.direction);
      localStorage.setItem('mk-shade', state.shade);
      localStorage.setItem('mk-role', state.role);
    };

    document.querySelectorAll('[data-direction]').forEach((btn) =>
      btn.addEventListener('click', () => {
        state.direction = btn.dataset.direction;
        apply();
      })
    );
    document.querySelectorAll('input[name="shade"]').forEach((el) => {
      el.checked = el.value === state.shade;
      el.addEventListener('change', () => {
        state.shade = el.value;
        apply();
      });
    });
    document.querySelectorAll('input[name="role"]').forEach((el) => {
      el.checked = el.value === state.role;
      el.addEventListener('change', () => {
        state.role = el.value;
        apply();
      });
    });

    apply();
  </script>
</Base>
