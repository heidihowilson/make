---
import Base from '../layouts/Base.astro';
---

<Base title="Home">
  <h1>sethmakes design system</h1>
  <p>
    Framework-neutral UI packages implementing one design language: terminal
    bones, calm surface. Monospace everywhere, zero radius, flat tonal
    surfaces with zero borders, pure achromatic grays, one moss-green hero
    accent, quietly alive motion.
  </p>
  <p>
    Chosen from rendered directions, not questionnaires.
    <a href="/directions">See the directions explorer →</a>
  </p>

  <div class="mk-card" style="margin-top: var(--mk-space-6);">
    <h3>Quick taste</h3>
    <p style="display: flex; gap: var(--mk-space-3); flex-wrap: wrap;">
      <button class="mk-btn mk-btn--primary">Primary</button>
      <button class="mk-btn">Default</button>
      <button class="mk-btn mk-btn--ghost">Ghost</button>
    </p>
    <p style="display: flex; gap: var(--mk-space-2); flex-wrap: wrap;">
      <span class="mk-badge mk-badge--accent">accent</span>
      <span class="mk-badge mk-badge--success">success</span>
      <span class="mk-badge mk-badge--warning">warning</span>
      <span class="mk-badge mk-badge--danger">danger</span>
      <span class="mk-badge">neutral</span>
    </p>
    <progress class="mk-progress" max="100" value="62"></progress>
  </div>
</Base>
