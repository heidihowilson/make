---
import Base from '../../layouts/Ui.astro';

// Normalize: Astro's BASE_URL has no trailing slash when base is '/make',
// and base+path without a separator produced /makeicons/... 404s in prod.
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const link = (path: string) => (base + path.replace(/^\//, '')).replace(/\/+/g, '/');

const components = [
  { href: '/ui/components/typography', name: 'typography', desc: 'Monospace scale, prose, headings.' },
  { href: '/ui/components/buttons', name: 'buttons', desc: 'Tonal, primary, ghost, danger, badges.' },
  { href: '/ui/components/forms', name: 'forms', desc: 'Filled inputs, selects, choices, switches.' },
  { href: '/ui/components/surfaces', name: 'surfaces', desc: 'Cards, tables, dividers, disclosure.' },
  { href: '/ui/components/feedback', name: 'feedback', desc: 'Alerts, badges, progress, spinners.' },
  { href: '/ui/components/media', name: 'media', desc: 'Thumbnails, figures, skeletons.' },
];
---

<Base title="ui">
  <header class="hero">
    <h1>sethmakes-ui</h1>
    <p class="hero__lede">
      The toolbox's UI library — framework-neutral packages implementing one
      design language: <strong>terminal bones, calm surface.</strong>
    </p>
  </header>

  <section class="mk-card" aria-labelledby="what">
    <h2 id="what">What it is</h2>
    <p>
      Monospace type everywhere, zero corner radius, flat tonal surfaces with
      <strong>zero borders</strong> — hierarchy comes from background shifts, not
      lines. One muted moss-green hero accent fills primary actions and marks
      links and focus; functional status colors exist only to mean things.
      Density sits in the comfortable middle, and motion is quietly alive.
      A machine voice, not a costume.
    </p>
    <p>
      Decided from rendered directions, not questionnaires — the decision
      trail lives in the repo's design docs.
    </p>
  </section>

  <section aria-labelledby="components">
    <h2 id="components">Components</h2>
    <ul class="index">
      {components.map((c) => (
        <li class="mk-card index__item">
          <a class="index__link" href={link(c.href)}>{c.name} →</a>
          <span class="index__desc">{c.desc}</span>
        </li>
      ))}
    </ul>
  </section>

  <section class="mk-card" aria-labelledby="install">
    <h2 id="install">Install</h2>
    <p>Pull tokens + css for the look with zero JS, then import them once.</p>
    <pre><code>pnpm add @sethmakes/tokens @sethmakes/css</code></pre>
    <pre><code>/* app entry CSS */
@import "@sethmakes/tokens/index.css";
@import "@sethmakes/tokens/fonts.css";
@import "@sethmakes/css/index.css";</code></pre>
    <p class="install-note">
      <strong>Fonts note:</strong> fonts.css references its woff2 files with
      relative URLs. Vite rebases these automatically; Tailwind's standalone
      CLI does not — copy <code>node_modules/@sethmakes/tokens/fonts/</code>
      into your public assets at build time if fonts 404.
    </p>

    <h3 id="tailwind">With Tailwind v4</h3>
    <p>
      sethmakes-ui and Tailwind coexist by design — Tailwind handles layout,
      sethmakes handles components. Two rules: import sethmakes
      <em>first</em>, and skip Tailwind's preflight (it lands after
      <code>mk.base</code> in the cascade and overwrites heading and link
      styles). sethmakes' reset zeroes <code>body</code> only, so bring a
      small margin reset of your own:
    </p>
    <pre><code>/* app entry CSS — order matters */
@import "@sethmakes/tokens/index.css";
@import "@sethmakes/tokens/fonts.css";
@import "@sethmakes/css/index.css";

/* Tailwind v4 without preflight: import the layers you use */
@import "tailwindcss/theme" layer(theme);
@import "tailwindcss/utilities" layer(utilities);

/* minimal margin reset (preflight normally does this) */
@layer base &#123;
  h1, h2, h3, h4, p, ul, ol &#123; margin: 0; &#125;
&#125;</code></pre>
    <p class="install-note">
      Tailwind utilities layer after <code>mk.components</code>, so
      <code>p-3</code> tightening an <code>mk-card</code> or
      <code>text-sm</code> resizing a heading just works — no specificity
      fights.
    </p>

    <h3 id="standalone-cli">With Tailwind's standalone CLI</h3>
    <p>
      Apps that compile with <code>@tailwindcss/cli</code> (no Vite, no
      PostCSS) follow the same layering, plus <strong>one gotcha</strong>: the
      standalone CLI does not rebase relative <code>url()</code>s, so
      <code>fonts.css</code> ships <code>./fonts/…</code> verbatim and the
      woff2 files 404. Copy them into your served assets at build time:
    </p>
    <pre><code>// package.json
"scripts": &#123;
  "fonts": "cp -r node_modules/@sethmakes/tokens/fonts public/fonts",
  "build:css": "npm run fonts &amp;&amp; tailwindcss -i styles/app.css -o public/app.css"
&#125;</code></pre>
    <pre><code>/* styles/app.css — sethmakes first, Tailwind layers after */
@import "@sethmakes/tokens/index.css";
@import "@sethmakes/tokens/fonts.css";
@import "@sethmakes/css/index.css";

@import "tailwindcss/theme" layer(theme);
@import "tailwindcss/utilities" layer(utilities);

@source "./app/**/*.&#123;ts,tsx&#125;";   /* keep your content globs */

/* the only preflight rule worth re-adding */
@layer base &#123; h1, h2, h3, h4, p, ul, ol &#123; margin: 0; &#125; &#125;</code></pre>
    <p class="install-note">
      Serve the compiled CSS from web root so its <code>./fonts/</code>
      resolves to the copied <code>/fonts/</code>. Remix v3 + this CLI is the
      reference setup.
    </p>
  </section>

  <section class="mk-card" aria-labelledby="migrate-daisy">
    <h2 id="migrate-daisy">Migrating off DaisyUI</h2>
    <p>
      Coming from a DaisyUI app pinned to one theme (the
      <code>data-theme="nord"</code> shape)? Remove <code>@plugin
      "daisyui"</code> and the theme pin. sethmakes drives every color through
      <code>color-scheme</code> + <code>light-dark()</code> on the system
      preference, so you <strong>gain dark mode for free</strong> — or pin
      <code>&lt;html data-theme="light"&gt;</code> to stay single-mode.
    </p>
    <p>Remap the daisy tokens you were using:</p>
    <ul class="remap">
      <li><code>base-100</code> → <code>--mk-color-bg</code></li>
      <li><code>base-200</code> → <code>--mk-color-surface-1</code></li>
      <li><code>base-300</code> → <code>--mk-color-surface-2</code> / <code>-3</code></li>
      <li><code>base-content</code> → <code>--mk-color-text</code></li>
      <li><code>base-content/50</code> → <code>--mk-color-text-muted</code></li>
      <li><code>base-content/40</code> → <code>--mk-color-text-faint</code></li>
      <li><code>primary</code> → <code>--mk-color-accent</code></li>
      <li><code>primary-content</code> → <code>--mk-color-accent-contrast</code></li>
      <li><code>warning</code> → <code>--mk-color-warning</code></li>
      <li><code>error</code> → <code>--mk-color-danger</code></li>
      <li><code>info</code> → no color token — use a tonal surface or <code>.mk-alert--info</code></li>
    </ul>
    <p class="install-note">
      There is deliberately no blue "info" hue: moss is the only non-status
      accent.
    </p>

    <h3 id="migrate-e2e">Playwright selectors</h3>
    <p>
      The restyle changes <strong>classes, not roles, labels, or routes</strong>.
      Two kinds of selector to know about:
    </p>
    <ul class="remap">
      <li><strong>Update these</strong> — class-coupled: <code>.card</code> → <code>.mk-card</code>, <code>li.card</code> → <code>li.mk-card</code>.</li>
      <li><strong>These survive untouched</strong> — <code>getByRole</code>, <code>getByPlaceholder</code>, <code>getByText</code>, <code>form[action=…]</code>, button labels, and native <code>confirm()</code> dialog auto-accept. The library changes how things look, not what they are.</li>
    </ul>
    <p class="install-note">
      Prefer role/label/placeholder selectors going forward — they don't break
      on the next restyle.
    </p>
  </section>

  <section class="mk-card" aria-labelledby="recipes">
    <h2 id="recipes">Recipes</h2>

    <h3 id="recipe-bottom-nav">Mobile bottom tab bar</h3>
    <p>
      The library ships the chrome — <code>.mk-appbar--bottom</code> is a
      fixed-to-bottom translucent surface, safe-area padded (the one sanctioned
      translucency). The per-tab layout (icon over a tiny label, a fixed tab
      height) is app layout, so Tailwind owns it. Mark the active tab with the
      accent color token; render adult-only or conditional tabs server-side.
    </p>
    <pre><code>&lt;nav class="mk-appbar mk-appbar--bottom" aria-label="Primary"&gt;
  &lt;a href="/" class="mk-link-reset flex flex-col items-center gap-1
                     min-h-[56px] justify-center
                     text-[color:var(--mk-color-accent)]"&gt;
    &lt;span class="mk-icon icon-[mk--home]"&gt;&lt;/span&gt;
    &lt;span class="text-[11px]"&gt;Home&lt;/span&gt;
  &lt;/a&gt;
  &lt;a href="/week" class="mk-link-reset flex flex-col items-center gap-1
                         min-h-[56px] justify-center"&gt;
    &lt;span class="mk-icon icon-[mk--calendar]"&gt;&lt;/span&gt;
    &lt;span class="text-[11px]"&gt;Week&lt;/span&gt;
  &lt;/a&gt;
  &#123;/* conditional tab — render only when allowed */&#125;
&lt;/nav&gt;</code></pre>
    <p class="install-note">
      <code>.mk-link-reset</code> strips the moss link color/underline so the
      tab paints its own state; the active color reads
      <code>var(--mk-color-accent)</code> directly so it tracks light/dark.
    </p>

    <h3 id="recipe-loading">Loading &amp; async states</h3>
    <p>
      Fully server-rendered apps need none of these — but when you add client
      interactivity the vocabulary is already here:
      <code>.mk-spinner</code> (<code>--sm</code> / <code>--md</code>),
      <code>.mk-progress</code> (drop <code>value</code> for an indeterminate
      bar), and <code>.mk-skeleton</code> / <code>.mk-skeleton--text</code>.
      All reduced-motion guarded. See the
      <a href={link('/ui/components/feedback')}>feedback</a> and
      <a href={link('/ui/components/media')}>media</a> pages.
    </p>

    <h3 id="recipe-native-inputs">Native inputs, no theming needed</h3>
    <p>
      A number stepper (<code>&lt;input type="number" min="0" max="7"&gt;</code>)
      and a datalist typeahead (<code>&lt;input list&gt;</code> +
      <code>&lt;datalist&gt;</code>) are just <code>.mk-input</code>. Their
      dropdown and spinner are browser chrome — un-styleable cross-browser by
      spec — so there's no <code>.mk-stepper</code> or <code>.mk-combobox</code>,
      and you don't need one. A styled combobox would be a future
      <code>@sethmakes/components</code> element.
    </p>
  </section>

  <section class="mk-card" aria-labelledby="sampler">
    <h2 id="sampler">Sampler</h2>
    <p>A taste in the current mode. Flip the toggle up top to see both.</p>
    <div class="row">
      <button class="mk-btn mk-btn--primary">Mark watched</button>
      <button class="mk-btn">Default</button>
      <button class="mk-btn mk-btn--ghost">Ghost</button>
    </div>
    <div class="row">
      <span class="mk-badge mk-badge--accent">accent</span>
      <span class="mk-badge mk-badge--success">aired</span>
      <span class="mk-badge mk-badge--warning">delayed</span>
      <span class="mk-badge mk-badge--danger">cancelled</span>
      <span class="mk-badge">neutral</span>
    </div>
    <div class="mk-field">
      <label for="sample-q">Search shows</label>
      <input id="sample-q" class="mk-input" type="search" placeholder="The Bear" />
    </div>
    <div class="mk-alert mk-alert--success">
      <span class="mk-alert__title">Synced</span>
      <span>Watch history is up to date.</span>
    </div>
    <progress class="mk-progress" max="100" value="62"></progress>
  </section>

  <style>
    .hero {
      padding-block: var(--mk-space-5) var(--mk-space-6);
    }

    .hero__lede {
      font-size: var(--mk-text-lg);
      color: var(--mk-color-text-muted);
      max-width: 44ch;
    }

    .hero__lede strong {
      color: var(--mk-color-text);
    }

    section + section,
    .mk-card + section,
    section + .mk-card {
      margin-top: var(--mk-space-6);
    }

    .index {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      gap: var(--mk-space-3);
      grid-template-columns: 1fr;
    }

    .index__item {
      display: flex;
      flex-direction: column;
      gap: var(--mk-space-1);
    }

    .index__link {
      font-weight: var(--mk-weight-bold);
    }

    .index__desc {
      color: var(--mk-color-text-muted);
      font-size: var(--mk-text-sm);
    }

    .row {
      display: flex;
      flex-wrap: wrap;
      gap: var(--mk-space-3);
      align-items: center;
      margin-block: var(--mk-space-4);
    }

    .install-note {
      color: var(--mk-color-text-muted);
      font-size: var(--mk-text-sm);
    }

    .remap {
      margin-block: var(--mk-space-3);
      padding-left: var(--mk-space-5);
      display: grid;
      gap: var(--mk-space-2);
      font-size: var(--mk-text-sm);
    }

    .mk-card pre {
      overflow-x: auto;
    }

    @media (min-width: 40rem) {
      .index {
        grid-template-columns: 1fr 1fr;
      }
    }
  </style>
</Base>
