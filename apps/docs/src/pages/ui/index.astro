---
import Base from '../../layouts/Ui.astro';

// Normalize: Astro's BASE_URL has no trailing slash when base is '/make',
// and base+path without a separator produced /makeicons/... 404s in prod.
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const link = (path: string) => (base + path.replace(/^\//, '')).replace(/\/+/g, '/');

const components = [
  { href: '/ui/components/typography', name: 'typography', desc: 'Monospace scale, prose, headings.' },
  { href: '/ui/components/buttons', name: 'buttons', desc: 'Tonal, primary, ghost, danger, badges.' },
  { href: '/ui/components/forms', name: 'forms', desc: 'Filled inputs, selects, choices, switches.' },
  { href: '/ui/components/surfaces', name: 'surfaces', desc: 'Cards, tables, dividers, disclosure.' },
  { href: '/ui/components/feedback', name: 'feedback', desc: 'Alerts, badges, progress, spinners.' },
  { href: '/ui/components/media', name: 'media', desc: 'Thumbnails, figures, skeletons.' },
];
---

<Base title="ui">
  <header class="hero">
    <h1>sethmakes-ui</h1>
    <p class="hero__lede">
      The toolbox's UI library — framework-neutral packages implementing one
      design language: <strong>terminal bones, calm surface.</strong>
    </p>
  </header>

  <section class="mk-card" aria-labelledby="what">
    <h2 id="what">What it is</h2>
    <p>
      Monospace type everywhere, zero corner radius, flat tonal surfaces with
      <strong>zero borders</strong> — hierarchy comes from background shifts, not
      lines. One muted moss-green hero accent fills primary actions and marks
      links and focus; functional status colors exist only to mean things.
      Density sits in the comfortable middle, and motion is quietly alive.
      A machine voice, not a costume.
    </p>
    <p>
      Decided from rendered directions, not questionnaires — the decision
      trail lives in the repo's design docs.
    </p>
  </section>

  <section aria-labelledby="components">
    <h2 id="components">Components</h2>
    <ul class="index">
      {components.map((c) => (
        <li class="mk-card index__item">
          <a class="index__link" href={link(c.href)}>{c.name} →</a>
          <span class="index__desc">{c.desc}</span>
        </li>
      ))}
    </ul>
  </section>

  <section class="mk-card" aria-labelledby="install">
    <h2 id="install">Install</h2>
    <p>Pull tokens + css for the look with zero JS, then import them once.</p>
    <pre><code>pnpm add @sethmakes/tokens @sethmakes/css</code></pre>
    <pre><code>/* app entry CSS */
@import "@sethmakes/tokens/index.css";
@import "@sethmakes/tokens/fonts.css";
@import "@sethmakes/css/index.css";</code></pre>
    <p class="install-note">
      <strong>Fonts note:</strong> fonts.css references its woff2 files with
      relative URLs. Vite rebases these automatically; Tailwind's standalone
      CLI does not — copy <code>node_modules/@sethmakes/tokens/fonts/</code>
      into your public assets at build time if fonts 404.
    </p>

    <h3 id="tailwind">With Tailwind v4</h3>
    <p>
      sethmakes-ui and Tailwind coexist by design — Tailwind handles layout,
      sethmakes handles components. Two rules: import sethmakes
      <em>first</em>, and skip Tailwind's preflight (it lands after
      <code>mk.base</code> in the cascade and overwrites heading and link
      styles). sethmakes' reset zeroes <code>body</code> only, so bring a
      small margin reset of your own:
    </p>
    <pre><code>/* app entry CSS — order matters */
@import "@sethmakes/tokens/index.css";
@import "@sethmakes/tokens/fonts.css";
@import "@sethmakes/css/index.css";

/* Tailwind v4 without preflight: import the layers you use */
@import "tailwindcss/theme" layer(theme);
@import "tailwindcss/utilities" layer(utilities);

/* minimal margin reset (preflight normally does this) */
@layer base &#123;
  h1, h2, h3, h4, p, ul, ol &#123; margin: 0; &#125;
&#125;</code></pre>
    <p class="install-note">
      Tailwind utilities layer after <code>mk.components</code>, so
      <code>p-3</code> tightening an <code>mk-card</code> or
      <code>text-sm</code> resizing a heading just works — no specificity
      fights.
    </p>
  </section>

  <section class="mk-card" aria-labelledby="sampler">
    <h2 id="sampler">Sampler</h2>
    <p>A taste in the current mode. Flip the toggle up top to see both.</p>
    <div class="row">
      <button class="mk-btn mk-btn--primary">Mark watched</button>
      <button class="mk-btn">Default</button>
      <button class="mk-btn mk-btn--ghost">Ghost</button>
    </div>
    <div class="row">
      <span class="mk-badge mk-badge--accent">accent</span>
      <span class="mk-badge mk-badge--success">aired</span>
      <span class="mk-badge mk-badge--warning">delayed</span>
      <span class="mk-badge mk-badge--danger">cancelled</span>
      <span class="mk-badge">neutral</span>
    </div>
    <div class="mk-field">
      <label for="sample-q">Search shows</label>
      <input id="sample-q" class="mk-input" type="search" placeholder="The Bear" />
    </div>
    <div class="mk-alert mk-alert--success">
      <span class="mk-alert__title">Synced</span>
      <span>Watch history is up to date.</span>
    </div>
    <progress class="mk-progress" max="100" value="62"></progress>
  </section>

  <style>
    .hero {
      padding-block: var(--mk-space-5) var(--mk-space-6);
    }

    .hero__lede {
      font-size: var(--mk-text-lg);
      color: var(--mk-color-text-muted);
      max-width: 44ch;
    }

    .hero__lede strong {
      color: var(--mk-color-text);
    }

    section + section,
    .mk-card + section,
    section + .mk-card {
      margin-top: var(--mk-space-6);
    }

    .index {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      gap: var(--mk-space-3);
      grid-template-columns: 1fr;
    }

    .index__item {
      display: flex;
      flex-direction: column;
      gap: var(--mk-space-1);
    }

    .index__link {
      font-weight: var(--mk-weight-bold);
    }

    .index__desc {
      color: var(--mk-color-text-muted);
      font-size: var(--mk-text-sm);
    }

    .row {
      display: flex;
      flex-wrap: wrap;
      gap: var(--mk-space-3);
      align-items: center;
      margin-block: var(--mk-space-4);
    }

    .install-note {
      color: var(--mk-color-text-muted);
      font-size: var(--mk-text-sm);
    }

    .mk-card pre {
      overflow-x: auto;
    }

    @media (min-width: 40rem) {
      .index {
        grid-template-columns: 1fr 1fr;
      }
    }
  </style>
</Base>
