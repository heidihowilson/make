---
import Base from '../../layouts/Icons.astro';

// The icon DISCOVERY TOOL — the reason this section exists. A fast, searchable
// browser over Lucide (~1770), Phosphor regular (~1530), and the mk brand
// aliases (~32). Performance is a requirement: NO SVGs are inlined into this
// HTML. Each tab's data is a trimmed JSON asset (names + svg bodies), built at
// /icons/data/<set>.json, fetched on demand and cached in memory. Search is
// debounced and results are capped (~120) with a "show more" — so the page is
// interactive instantly on a phone regardless of set size.

// BASE_URL-aware so it works under the GitHub Pages subpath. The client reads
// this off a data attribute rather than hardcoding "/".
const base = import.meta.env.BASE_URL;
const dataUrl = (set: string) => (base + `icons/data/${set}.json`).replace(/\/+/g, '/');
---

<Base title="browse">
  <header class="hero">
    <h1>Browse icons</h1>
    <p class="hero__lede">
      Search every glyph, <strong>click to copy</strong> its Tailwind class.
    </p>
  </header>

  <div
    class="browse"
    data-lucide={dataUrl('lucide')}
    data-ph={dataUrl('ph')}
    data-mk={dataUrl('mk')}
  >
    <!-- Set tabs. Buttons in a tablist; mk is the default (smallest, brand-most-
         relevant, instant). currentColor + tonal active state, zero borders. -->
    <div class="browse__tabs" role="tablist" aria-label="Icon set">
      <button class="browse__tab browse__tab--active" role="tab" aria-selected="true" data-set="mk" id="tab-mk" aria-controls="results">mk</button>
      <button class="browse__tab" role="tab" aria-selected="false" data-set="lucide" id="tab-lucide" aria-controls="results">lucide</button>
      <button class="browse__tab" role="tab" aria-selected="false" data-set="ph" id="tab-ph" aria-controls="results">phosphor</button>
    </div>

    <!-- Search. Labeled (label is visually compact but present), autofocus is
         applied by JS on desktop only to avoid yanking the viewport on phones. -->
    <div class="mk-field browse__search">
      <label for="icon-search">Search</label>
      <input
        class="mk-input"
        type="search"
        id="icon-search"
        placeholder="search by name…"
        autocomplete="off"
        autocapitalize="off"
        spellcheck="false"
        enterkeyhint="search"
      />
    </div>

    <p class="browse__count" id="result-count" aria-live="polite">Loading…</p>

    <!-- Results grid. Buttons only — keyboard accessible, visible focus. The
         grid is responsive from 360px via min-width queries. -->
    <div class="browse__grid" id="results" role="region" aria-label="Icon results"></div>

    <!-- Empty state, shown when a search matches nothing. -->
    <div class="mk-empty browse__empty" id="empty" hidden>
      <p class="mk-empty__title">No matches</p>
      <p class="mk-empty__message">Nothing in this set matches that name. Try a shorter term or another tab.</p>
    </div>

    <!-- Show-more reveals the next page of capped results. -->
    <div class="browse__more" id="more-wrap" hidden>
      <button class="mk-btn" id="show-more" type="button">Show more</button>
    </div>

    <!-- Polite live region for copy confirmation (announced to screen readers,
         separate from the visual toast so the announcement is text-only). -->
    <p class="browse__sr" id="copy-status" role="status" aria-live="polite"></p>
  </div>

  <!-- Visual copy confirmation toast. aria-hidden — the live region above carries
       the accessible announcement. -->
  <div class="browse__toast" id="toast" aria-hidden="true" hidden></div>

  <style>
    .hero {
      padding-block: var(--mk-space-5) var(--mk-space-5);
    }

    .hero__lede {
      font-size: var(--mk-text-lg);
      color: var(--mk-color-text-muted);
      max-width: 44ch;
    }

    .hero__lede strong {
      color: var(--mk-color-text);
    }

    /* Tabs — a tonal strip; the active tab is full-strength text on surface-3,
       the rest muted. No borders, no radius (terminal bones). 44px tall. */
    .browse__tabs {
      display: flex;
      flex-wrap: wrap;
      gap: var(--mk-space-1);
      margin-bottom: var(--mk-space-4);
    }

    .browse__tab {
      appearance: none;
      border: 0;
      border-radius: 0;
      background: var(--mk-color-surface-2);
      color: var(--mk-color-text-muted);
      font: inherit;
      font-size: var(--mk-text-sm);
      min-height: 44px;
      padding-inline: var(--mk-space-4);
      cursor: pointer;
      transition: background var(--mk-motion-quick) var(--mk-ease-out),
        color var(--mk-motion-quick) var(--mk-ease-out);
    }

    .browse__tab:hover {
      color: var(--mk-color-text);
    }

    .browse__tab--active {
      background: var(--mk-color-surface-3);
      color: var(--mk-color-text);
      font-weight: var(--mk-weight-bold);
    }

    /* Visible focus ring everywhere — moss, offset, no border anywhere else. */
    .browse__tab:focus-visible,
    .browse__cell:focus-visible,
    #show-more:focus-visible {
      outline: 2px solid var(--mk-color-accent);
      outline-offset: 2px;
    }

    .browse__search {
      margin-bottom: var(--mk-space-3);
    }

    /* Label present for a11y but kept tight (terse mono voice). */
    .browse__search > label {
      font-size: var(--mk-text-xs);
      color: var(--mk-color-text-muted);
    }

    .browse__count {
      font-size: var(--mk-text-xs);
      color: var(--mk-color-text-muted);
      margin-bottom: var(--mk-space-4);
      min-height: 1.2em; /* reserve space so the grid doesn't jump on update */
    }

    /* Results grid — auto-fill from 360px. Cells are square-ish tonal blocks. */
    .browse__grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(5rem, 1fr));
      gap: var(--mk-space-2);
    }

    .browse__cell {
      appearance: none;
      border: 0;
      border-radius: 0;
      background: var(--mk-color-surface-1);
      color: var(--mk-color-text);
      font: inherit;
      cursor: pointer;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--mk-space-2);
      padding: var(--mk-space-3) var(--mk-space-2);
      min-height: 44px;
      text-align: center;
      transition: background var(--mk-motion-quick) var(--mk-ease-out);
    }

    .browse__cell:hover {
      background: var(--mk-color-surface-3);
    }

    /* The glyph — currentColor, standalone-affordance size. The svg inside is
       set to 1em by iconToSVG, so font-size drives it. */
    .browse__glyph {
      font-size: var(--mk-icon-lg);
      line-height: 0;
      color: var(--mk-color-text);
    }

    .browse__glyph svg {
      display: block;
      width: 1em;
      height: 1em;
    }

    /* Name beneath, mono xs, muted, truncated mid-word so long names fit. */
    .browse__name {
      font-size: var(--mk-text-xs);
      color: var(--mk-color-text-muted);
      max-width: 100%;
      overflow-wrap: anywhere;
      line-height: var(--mk-leading-tight);
    }

    /* Brief moss flash on the cell that was just copied. */
    .browse__cell--copied {
      background: var(--mk-color-accent-subtle);
    }

    .browse__cell--copied .browse__name {
      color: var(--mk-color-on-accent-subtle);
    }

    .browse__empty {
      margin-top: var(--mk-space-4);
    }

    .browse__more {
      margin-top: var(--mk-space-5);
      display: flex;
      justify-content: center;
    }

    /* Screen-reader-only live region — visually hidden, still announced. */
    .browse__sr {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0 0 0 0);
      white-space: nowrap;
      border: 0;
    }

    /* Visual copy toast — fixed, tonal, fades. aria-hidden; SR uses the region. */
    .browse__toast {
      position: fixed;
      left: 50%;
      bottom: var(--mk-space-5);
      transform: translateX(-50%);
      z-index: var(--mk-layer-toast, 100);
      background: var(--mk-color-surface-3);
      color: var(--mk-color-text);
      font-size: var(--mk-text-sm);
      padding: var(--mk-space-3) var(--mk-space-4);
      /* No shadow: flat language; the toast separates via surface step + the toast layer. */
      max-width: calc(100vw - var(--mk-space-6));
    }

    .browse__toast code {
      color: var(--mk-color-accent);
    }

    @media (prefers-reduced-motion: no-preference) {
      .browse__toast {
        animation: browse-toast-in var(--mk-motion-standard) var(--mk-ease-out);
      }

      .browse__cell--copied {
        transition: background var(--mk-motion-quick) var(--mk-ease-out);
      }
    }

    @keyframes browse-toast-in {
      from { opacity: 0; transform: translate(-50%, var(--mk-space-3)); }
      to { opacity: 1; transform: translate(-50%, 0); }
    }

    /* Roomier cells once there's width to spare. min-width queries only. */
    @media (min-width: 30rem) {
      .browse__grid {
        grid-template-columns: repeat(auto-fill, minmax(6rem, 1fr));
        gap: var(--mk-space-3);
      }
    }
  </style>

  <script>
    // All client logic for the browser. Vanilla — this is the docs app, where
    // JS is allowed; the LIBRARY itself stays zero-JS. Per-tab data is fetched
    // once and cached in memory; search is debounced; results are capped.
    (() => {
      const root = document.querySelector<HTMLElement>('.browse');
      if (!root) return;

      const grid = document.getElementById('results') as HTMLElement;
      const countEl = document.getElementById('result-count') as HTMLElement;
      const emptyEl = document.getElementById('empty') as HTMLElement;
      const moreWrap = document.getElementById('more-wrap') as HTMLElement;
      const moreBtn = document.getElementById('show-more') as HTMLButtonElement;
      const input = document.getElementById('icon-search') as HTMLInputElement;
      const srStatus = document.getElementById('copy-status') as HTMLElement;
      const toast = document.getElementById('toast') as HTMLElement;
      const tabs = Array.from(
        root.querySelectorAll<HTMLButtonElement>('.browse__tab'),
      );

      const PAGE = 120; // visible-result cap; "show more" adds another page
      const DEBOUNCE = 150;

      const urls: Record<string, string> = {
        mk: root.dataset.mk || '',
        lucide: root.dataset.lucide || '',
        ph: root.dataset.ph || '',
      };

      // In-memory cache: set -> { vb, names[], icons{} } once fetched.
      const cache: Record<string, any> = {};

      let activeSet = 'mk';
      let query = '';
      let filtered: string[] = []; // names matching current query, in set order
      let shown = 0; // how many of `filtered` are currently rendered

      // Build one icon cell as a <button>. The svg body comes from the trimmed
      // asset; viewBox is the per-icon override or the set default.
      function makeCell(set: string, name: string, data: any): HTMLButtonElement {
        const entry = data.icons[name];
        const vb = entry.v || data.vb || '0 0 24 24';
        const cls = `icon-[${set}--${name}]`;

        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'browse__cell';
        btn.dataset.cls = cls;
        // Accessible name = the Tailwind class users are copying.
        btn.setAttribute('aria-label', `Copy ${cls}`);
        if (set === 'mk' && entry.src) {
          btn.title = `${cls} → ${entry.src}\n${entry.why || ''}`.trim();
        } else {
          btn.title = cls;
        }

        const glyph = document.createElement('span');
        glyph.className = 'browse__glyph';
        glyph.setAttribute('aria-hidden', 'true');
        // Bodies are trusted, static, build-generated Iconify output.
        glyph.innerHTML = `<svg viewBox="${vb}" fill="currentColor" xmlns="http://www.w3.org/2000/svg">${entry.b}</svg>`;

        const label = document.createElement('span');
        label.className = 'browse__name';
        label.textContent = name;

        btn.append(glyph, label);
        return btn;
      }

      // Render the next page of `filtered` into the grid (appends; never clears
      // mid-page so "show more" is cheap).
      function renderPage() {
        const data = cache[activeSet];
        const frag = document.createDocumentFragment();
        const end = Math.min(shown + PAGE, filtered.length);
        for (let i = shown; i < end; i++) {
          frag.appendChild(makeCell(activeSet, filtered[i], data));
        }
        grid.appendChild(frag);
        shown = end;
        moreWrap.hidden = shown >= filtered.length;
      }

      // Recompute the filtered list for the current query + set, reset paging.
      function applyFilter() {
        const data = cache[activeSet];
        if (!data) return;
        const q = query.trim().toLowerCase();
        const names = data.names as string[];
        filtered = q ? names.filter((n) => n.includes(q)) : names;

        grid.innerHTML = '';
        shown = 0;

        const total = (names as string[]).length;
        if (filtered.length === 0) {
          emptyEl.hidden = false;
          moreWrap.hidden = true;
          countEl.textContent = `0 of ${total}`;
          return;
        }
        emptyEl.hidden = true;
        countEl.textContent = `${filtered.length} of ${total}`;
        renderPage();
      }

      // Fetch + cache a set's trimmed JSON, then apply the current filter.
      async function loadSet(set: string) {
        if (cache[set]) {
          applyFilter();
          return;
        }
        countEl.textContent = 'Loading…';
        grid.innerHTML = '';
        emptyEl.hidden = true;
        moreWrap.hidden = true;
        try {
          const res = await fetch(urls[set]);
          if (!res.ok) throw new Error(String(res.status));
          const data = await res.json();
          // Precompute the name list once (set order) for fast filtering.
          data.names = Object.keys(data.icons);
          cache[set] = data;
          applyFilter();
        } catch {
          countEl.textContent = 'Could not load icons. Try refreshing.';
        }
      }

      // Copy a Tailwind class to the clipboard with visual + SR confirmation.
      async function copyClass(btn: HTMLButtonElement) {
        const cls = btn.dataset.cls || '';
        try {
          await navigator.clipboard.writeText(cls);
        } catch {
          // Fallback for older / insecure contexts.
          const ta = document.createElement('textarea');
          ta.value = cls;
          ta.style.position = 'fixed';
          ta.style.opacity = '0';
          document.body.appendChild(ta);
          ta.select();
          try { document.execCommand('copy'); } catch { /* give up quietly */ }
          ta.remove();
        }

        // Visual flash on the cell.
        btn.classList.add('browse__cell--copied');
        window.setTimeout(() => btn.classList.remove('browse__cell--copied'), 700);

        // Visual toast.
        toast.hidden = false;
        toast.innerHTML = `Copied <code>${cls}</code>`;
        window.clearTimeout((copyClass as any)._t);
        (copyClass as any)._t = window.setTimeout(() => { toast.hidden = true; }, 1600);

        // Accessible announcement (text-only, separate node).
        srStatus.textContent = `Copied ${cls}`;
      }

      // --- wiring ---

      // Tab switching.
      tabs.forEach((tab) => {
        tab.addEventListener('click', () => {
          if (tab.dataset.set === activeSet) return;
          tabs.forEach((t) => {
            const on = t === tab;
            t.classList.toggle('browse__tab--active', on);
            t.setAttribute('aria-selected', on ? 'true' : 'false');
          });
          activeSet = tab.dataset.set || 'mk';
          loadSet(activeSet);
        });
      });

      // Debounced search.
      let debounce: number | undefined;
      input.addEventListener('input', () => {
        window.clearTimeout(debounce);
        debounce = window.setTimeout(() => {
          query = input.value;
          applyFilter();
        }, DEBOUNCE);
      });

      // Show more.
      moreBtn.addEventListener('click', () => renderPage());

      // Copy on cell click (event-delegated — one listener for all cells).
      grid.addEventListener('click', (e) => {
        const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.browse__cell');
        if (btn) copyClass(btn);
      });

      // Autofocus the search on desktop only — pointer:fine + no touch — so a
      // phone keyboard never pops up over the grid on load.
      const isDesktop = window.matchMedia('(pointer: fine)').matches
        && !window.matchMedia('(pointer: coarse)').matches;
      if (isDesktop) input.focus();

      // Kick off with the default (mk) set.
      loadSet(activeSet);
    })();
  </script>
</Base>
