{
  "name": "@sethmakes/icons",
  "version": "0.1.6",
  "description": "Brand aliases, sizing conventions, and a custom Iconify set (prefix `mk`) for the sethmakes design language. Selection happens at YOUR build via Iconify — this package is thin.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/heidihowilson/make.git",
    "directory": "packages/icons"
  },
  "type": "module",
  "exports": {
    ".": "./dist/mk.json",
    "./mk.json": "./dist/mk.json",
    "./aliases.json": "./src/aliases.json"
  },
  "bin": {
    "sethmakes-icons": "./bin/sethmakes-icons.mjs"
  },
  "files": [
    "dist",
    "src/aliases.json",
    "bin",
    "scripts"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "prepublishOnly": "node scripts/build.mjs"
  },
  "dependencies": {
    "@iconify-json/lucide": "1.2.111",
    "@iconify-json/ph": "1.2.2",
    "@iconify/utils": "3.1.3"
  },
  "keywords": [
    "icons",
    "iconify",
    "tailwind",
    "lucide",
    "phosphor",
    "design-system"
  ]
}
